{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "nullalis-gateway",
      "runtimeExecutable": "zig",
      "runtimeArgs": ["build", "run", "--", "gateway", "--port", "3000", "--host", "127.0.0.1"],
      "port": 3000
    },
    {
      "name": "nullalis-gateway-debug",
      "runtimeExecutable": "zig",
      "runtimeArgs": ["build", "run", "-Doptimize=Debug", "--", "gateway", "--port", "3001", "--host", "127.0.0.1"],
      "port": 3001
    },
    {
      "name": "nullalis-test",
      "runtimeExecutable": "zig",
      "runtimeArgs": ["build", "test", "--summary", "all"]
    }
  ]
}
