{
  "$schema": "autoresearch-benchmark-v1",
  "description": "Highest-value failure-mode benchmarks for nullalis. Focus: proactive research, agentic execution, self-awareness.",
  "gateway": {
    "url": "http://127.0.0.1:3000/api/v1/chat/stream",
    "internal_token": "40ae970fce1815c0d076fdff8ac24c02b1a45bc905d909cd",
    "user_id": "1",
    "session_key_prefix": "agent:zaki-bot:user:1:bench"
  },
  "benchmarks": [
    {
      "id": "b1_unknown_term_search",
      "category": "proactive_research",
      "prompt": "Are you on par with openclaw? Tell me what you know about openclaw specifically.",
      "grading": {
        "must_call_any_of": ["web_search", "web_fetch"],
        "must_not_contain_phrases": [
          "I don't know what openclaw is",
          "I'm not familiar with openclaw",
          "I have no information about openclaw",
          "I cannot find any information"
        ],
        "weight": 1.0
      }
    },
    {
      "id": "b2_tenet_research",
      "category": "proactive_research",
      "prompt": "What is the 'Tenet framework' in AI agent research? Give me a one-sentence summary.",
      "grading": {
        "must_call_any_of": ["web_search", "web_fetch"],
        "must_not_contain_phrases": [
          "I don't know",
          "I'm not sure what",
          "I cannot find"
        ],
        "weight": 1.0
      }
    },
    {
      "id": "b3_self_awareness",
      "category": "self_awareness",
      "prompt": "Use your self-inspection tool to report your current execution mode, the tools you have available, and how many memories you have stored. Give me the actual values from the snapshot, not a general description.",
      "grading": {
        "must_call_any_of": ["context_snapshot"],
        "should_contain_any": ["mode", "tools", "memor"],
        "must_not_contain_phrases": [
          "I would check",
          "I can tell you that",
          "Typically I"
        ],
        "weight": 1.0
      }
    },
    {
      "id": "b4_agentic_file_read",
      "category": "agentic_execution",
      "prompt": "Read your AUTOMATIONS.json from your own workspace and tell me in one short sentence whether it has any entries. Actually read it, don't guess or answer from memory.",
      "grading": {
        "must_call_any_of": ["file_read", "shell"],
        "should_contain_any": ["automat", "entries", "empty", "no ", "0 ", "contains"],
        "must_not_contain_phrases": [
          "I would read",
          "I cannot read",
          "I don't have access"
        ],
        "weight": 1.0
      }
    },
    {
      "id": "b5_agentic_shell",
      "category": "agentic_execution",
      "prompt": "Run `date` in the shell and tell me the current time from the output. Use the actual tool — do not answer from guessing.",
      "grading": {
        "must_call_any_of": ["shell"],
        "should_contain_any": ["2026", "UTC", "EST", "CET", "PDT", "EDT", "CEST", ":"],
        "must_not_contain_phrases": [
          "I would run",
          "I cannot execute",
          "I don't have shell access"
        ],
        "weight": 1.0
      }
    },
    {
      "id": "b6_tool_choice_specificity",
      "category": "tool_discipline",
      "prompt": "I want to know the size of your own workspace directory. Use whichever tool is most specific for that job — explain your choice briefly.",
      "grading": {
        "must_call_any_of": ["shell"],
        "should_contain_any": ["du", "size", "bytes", "MB", "KB", "workspace"],
        "must_not_contain_phrases": [
          "I would use",
          "I cannot determine"
        ],
        "weight": 1.0
      }
    },
    {
      "id": "b7_error_recovery",
      "category": "agentic_execution",
      "prompt": "Read the file `/definitely/does/not/exist/ever.txt`. When it fails, try a different approach to report something useful — don't just repeat the error.",
      "grading": {
        "must_call_any_of": ["file_read", "shell"],
        "should_contain_any": ["does not exist", "not found", "no such", "missing", "absent", "failed"],
        "must_not_contain_phrases": [
          "I would try",
          "I cannot attempt"
        ],
        "weight": 1.0
      }
    },
    {
      "id": "b8_memory_context_anchor",
      "category": "memory_recall",
      "prompt": "Recall what channel and session lane we're currently talking through. Use your self-inspection + memory tools; actually check, don't guess.",
      "grading": {
        "must_call_any_of": ["context_snapshot", "runtime_info", "memory_recall", "memory_list", "memory_timeline"],
        "should_contain_any": ["bench", "thread", "session", "zaki"],
        "must_not_contain_phrases": [
          "I would check",
          "I cannot determine",
          "I don't know which"
        ],
        "weight": 1.0
      }
    },
    {
      "id": "b9_unknown_person_name",
      "category": "proactive_research",
      "prompt": "Who is Yoshua Bengio? Give me three specific affiliations or contributions. If uncertain, verify first.",
      "grading": {
        "must_call_any_of": ["web_search", "web_fetch"],
        "should_contain_any": ["Bengio", "Montreal", "deep learning", "neural", "Mila", "Turing"],
        "must_not_contain_phrases": [
          "Based on my memory",
          "From my earlier search",
          "I don't know who"
        ],
        "weight": 1.0
      }
    },
    {
      "id": "b10_schedule_tool_prefer",
      "category": "tool_discipline",
      "prompt": "What time is it right now in UTC? Use the most appropriate nullalis tool (hint: there is one specifically for runtime/time info, more specific than shell).",
      "grading": {
        "must_call_any_of": ["runtime_info", "schedule", "shell", "context_snapshot"],
        "should_contain_any": ["2026", "UTC", ":"],
        "must_not_contain_phrases": [
          "I don't have a clock",
          "I cannot tell time"
        ],
        "weight": 1.0
      }
    }
  ]
}
