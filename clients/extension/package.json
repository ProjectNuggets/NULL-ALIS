{
  "name": "nullalis-extension",
  "version": "0.1.0",
  "private": true,
  "description": "nullalis browser extension — the agent drives the user's own browser with the user's own logged-in sessions",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && vite build --config vite.content.config.ts",
    "icons": "bash scripts/gen-icons.sh",
    "package": "npm run build && cd dist && zip -r ../nullalis-extension.zip . && cd ..",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "happy-dom": "^20.9.0",
    "typescript": "^5.5.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "@crxjs/vite-plugin": {
      "rollup": "2.80.0"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
